# ---- Neon database ----
# Neon Console -> your project -> Connect -> copy the connection string.
DATABASE_URL=

# ---- Auth.js ----
# Generate once with:  npx auth secret    (or: openssl rand -base64 33)
AUTH_SECRET=

# Google OAuth credentials (Auth.js reads these automatically).
# Create at https://console.cloud.google.com -> Credentials -> OAuth client ID.
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- DEV ONLY password-less login ----
# Lets you sign in locally without Google. Set BOTH to true for local testing.
# NEVER enable in production.
AUTH_DEV_LOGIN=false
NEXT_PUBLIC_AUTH_DEV_LOGIN=false
